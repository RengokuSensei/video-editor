{
  "manifest_version": 3,
  "name": "Wasm High-Performance Video Editor",
  "version": "1.0.0",
  "description": "Chrome Extension powered by a C++ WebAssembly video editing engine.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "action": {
    "default_popup": "index.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
